{
  "name": "xeneize-regaleria",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @xeneize/web --filter @xeneize/admin --filter @xeneize/api dev",
    "dev:web": "corepack pnpm --filter @xeneize/web dev",
    "dev:admin": "corepack pnpm --filter @xeneize/admin dev",
    "dev:api": "corepack pnpm --filter @xeneize/api dev",
    "build": "corepack pnpm -r --if-present build",
    "lint": "corepack pnpm -r --if-present lint"
  }
}
